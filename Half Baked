class CarRentalSystem:
    def __init__(self):
        self.active_rentals = RentalLinkedList()
        self.car_tree = CarBST()
        
        self.plate_hash = HashTable()      # plate -> Car
        self.customer_hash = HashTable()   # customer_id -> Customer
        
        self._all_cars_list = []           # cached list for sorting (updated when cars change)
        self._last_car_list_update = 0
        self._next_rental_id = 1

    def add_car(self, car: Car):
        self.car_tree.insert(car)
        self.plate_hash.insert(car.plate, car)
        self._invalidate_car_list()

    def get_car_by_id(self, car_id: int) -> Optional[Car]:
        return self.car_tree.search(car_id)

    def get_car_by_plate(self, plate: str) -> Optional[Car]:
        return self.plate_hash.get(plate)

    def add_customer(self, customer: Customer):
        self.customer_hash.insert(customer.customer_id, customer)

    def get_customer(self, customer_id: int) -> Optional[Customer]:
        return self.customer_hash.get(customer_id)

    def rent_car(self, car_id: int, customer_id: int, rent_date: datetime.date) -> bool:
        car = self.get_car_by_id(car_id)
        if not car:
            print("Car not found.")
            return False
        if not car.available:
            print("Car is already rented.")
            return False
        customer = self.get_customer(customer_id)
        if not customer:
            print("Customer not found.")
            return False
        # Create rental record
        rental_id = self._generate_rental_id()
        rental = Rental(rental_id, car, customer, rent_date)
        self.active_rentals.add_rental(rental)
        car.available = False
        print(f"Car {car_id} rented to {customer.name} (ID: {customer_id}).")
        return True

    def return_car(self, rental_id: int, return_date: datetime.date) -> bool:
        rental = self.active_rentals.remove_rental(rental_id)
        if not rental:
            print("Rental record not found.")
            return False
        rental.return_date = return_date
        rental.car.available = True
        
        # Optionally store in a history list 
        print(f"Car {rental.car.car_id} returned.")
        return True

    def display_active_rentals(self):
        self.active_rentals.display()

    def display_all_cars(self):
        cars = self.car_tree.inorder()
        if not cars:
            print("No cars in inventory.")
        else:
            for car in cars:
                print(car)

    # Sorting and searching (Student 3)
    def get_sorted_cars(self, key: str) -> List[Car]:
        cars = self._get_all_cars_list()
        if key == 'model':
            return merge_sort_cars(cars, by_model)
        elif key == 'price':
            return merge_sort_cars(cars, by_price)
        elif key == 'availability':
            return merge_sort_cars(cars, by_availability)
        else:
            return cars

    def search_cars_by_model(self, model: str) -> List[Car]:
        sorted_cars = self.get_sorted_cars('model')
        return binary_search_cars(sorted_cars, by_model, model)

    def _get_all_cars_list(self) -> List[Car]:
        return self.car_tree.inorder()

    def _invalidate_car_list(self):
        # For caching, but we won't implement caching for simplicity
        pass

    def _generate_rental_id(self):
        rental_id = self._next_rental_id
        self._next_rental_id += 1
        return rental_id

