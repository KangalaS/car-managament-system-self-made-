# Sorting functions (Merge Sort example)
def merge_sort_cars(cars: List[Car], key_func) -> List[Car]:
    """Sort list of cars using merge sort based on key_func."""
    if len(cars) <= 1:
        return cars
    mid = len(cars) // 2
    left = merge_sort_cars(cars[:mid], key_func)
    right = merge_sort_cars(cars[mid:], key_func)
    return _merge(left, right, key_func)

def _merge(left: List[Car], right: List[Car], key_func):
    result = []
    i = j = 0
    while i < len(left) and j < len(right):
        if key_func(left[i]) <= key_func(right[j]):
            result.append(left[i])
            i += 1
        else:
            result.append(right[j])
            j += 1
    result.extend(left[i:])
    result.extend(right[j:])
    return result

