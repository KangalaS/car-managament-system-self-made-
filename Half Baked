class ListNode:
    def __init__(self, rental: Rental):
        self.rental = rental
        self.next = None

class RentalLinkedList:
    def __init__(self):
        self.head = None
        self.size = 0

    def add_rental(self, rental: Rental) -> None:
        """Add a rental at the front."""
        new_node = ListNode(rental)
        new_node.next = self.head
        self.head = new_node
        self.size += 1

    def remove_rental(self, rental_id: int) -> Optional[Rental]:
        """Remove rental by ID and return it."""
        if not self.head:
            return None
        # If head is the target
        if self.head.rental.rental_id == rental_id:
            removed = self.head.rental
            self.head = self.head.next
            self.size -= 1
            return removed
        # Search in rest
        current = self.head
        while current.next:
            if current.next.rental.rental_id == rental_id:
                removed = current.next.rental
                current.next = current.next.next
                self.size -= 1
                return removed
            current = current.next
        return None

    def display(self) -> None:
        """Traverse and print all rentals."""
        current = self.head
        if not current:
            print("No active rentals.")
            return
        while current:
            print(current.rental)
            current = current.next

#Binary search tree for cars
class BSTNode:
    def __init__(self, car: Car):
        self.car = car
        self.left = None
        self.right = None

class CarBST:
    def __init__(self):
        self.root = None

    def insert(self, car: Car) -> None:
        """Insert car into BST by car_id."""
        self.root = self._insert_rec(self.root, car)

    def _insert_rec(self, node: Optional[BSTNode], car: Car) -> BSTNode:
        if node is None:
            return BSTNode(car)
        if car.car_id < node.car.car_id:
            node.left = self._insert_rec(node.left, car)
        elif car.car_id > node.car.car_id:
            node.right = self._insert_rec(node.right, car)
        else:
            # Car ID already exists – we can update or ignore; here we ignore
            pass
        return node

    def search(self, car_id: int) -> Optional[Car]:
        """Search car by ID."""
        node = self._search_rec(self.root, car_id)
        return node.car if node else None

    def _search_rec(self, node: Optional[BSTNode], car_id: int) -> Optional[BSTNode]:
        if node is None or node.car.car_id == car_id:
            return node
        if car_id < node.car.car_id:
            return self._search_rec(node.left, car_id)
        else:
            return self._search_rec(node.right, car_id)

    def delete(self, car_id: int) -> bool:
        """Delete car by ID. Return True if deleted."""
        self.root, deleted = self._delete_rec(self.root, car_id)
        return deleted

    def _delete_rec(self, node: Optional[BSTNode], car_id: int):
        if node is None:
            return None, False
        if car_id < node.car.car_id:
            node.left, deleted = self._delete_rec(node.left, car_id)
            return node, deleted
        elif car_id > node.car.car_id:
            node.right, deleted = self._delete_rec(node.right, car_id)
            return node, deleted
        else:
            # Node to delete
            if node.left is None:
                return node.right, True
            if node.right is None:
                return node.left, True
            # Two children: find inorder successor
            successor = self._min_value_node(node.right)
            node.car = successor.car
            node.right, _ = self._delete_rec(node.right, successor.car.car_id)
            return node, True

    def _min_value_node(self, node: BSTNode) -> BSTNode:
        current = node
        while current.left:
            current = current.left
        return current

    # Recursive traversals 
    """Student 2"""
    def inorder(self) -> List[Car]:
        result = []
        self._inorder_rec(self.root, result)
        return result

    def _inorder_rec(self, node: Optional[BSTNode], result: List[Car]):
        if node:
            self._inorder_rec(node.left, result)
            result.append(node.car)
            self._inorder_rec(node.right, result)

    def preorder(self) -> List[Car]:
        result = []
        self._preorder_rec(self.root, result)
        return result

    def _preorder_rec(self, node: Optional[BSTNode], result: List[Car]):
        if node:
            result.append(node.car)
            self._preorder_rec(node.left, result)
            self._preorder_rec(node.right, result)

    def postorder(self) -> List[Car]:
        result = []
        self._postorder_rec(self.root, result)
        return result

    def _postorder_rec(self, node: Optional[BSTNode], result: List[Car]):
        if node:
            self._postorder_rec(node.left, result)
            self._postorder_rec(node.right, result)
            result.append(node.car)

    def count_cars(self) -> int:
        """Recursively count total cars (Student 2)."""
        return self._count_rec(self.root)

    def _count_rec(self, node: Optional[BSTNode]) -> int:
        if node is None:
            return 0
        return 1 + self._count_rec(node.left) + self._count_rec(node.right)

    def count_available(self) -> int:
        """Count available cars recursively."""
        return self._count_available_rec(self.root)

    def _count_available_rec(self, node: Optional[BSTNode]) -> int:
        if node is None:
            return 0
        count = 1 if node.car.available else 0
        return count + self._count_available_rec(node.left) + self._count_available_rec(node.right)

