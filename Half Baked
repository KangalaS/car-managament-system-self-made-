class HashTable:
    def __init__(self):
        self.table = {}

    def insert(self, key, value):
        self.table[key] = value

    def get(self, key):
        return self.table.get(key)

    def delete(self, key):
        if key in self.table:
            del self.table[key]
            return True
        return False

    def contains(self, key):
        return key in self.table

