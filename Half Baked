# Binary search on sorted list
def binary_search_cars(sorted_cars: List[Car], key_func, target) -> Optional[List[Car]]:
    """
    Search for all cars that match target under key_func.
    Assumes sorted_cars is sorted by key_func.
    Returns list of matches.
    """
    # First find the leftmost index where key >= target
    low, high = 0, len(sorted_cars)
    while low < high:
        mid = (low + high) // 2
        if key_func(sorted_cars[mid]) < target:
            low = mid + 1
        else:
            high = mid
    left = low
    # Then find rightmost index where key <= target
    low, high = 0, len(sorted_cars)
    while low < high:
        mid = (low + high) // 2
        if key_func(sorted_cars[mid]) <= target:
            low = mid + 1
        else:
            high = mid
    right = low
    return sorted_cars[left:right] if left < right else []

