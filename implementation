import datetime
from typing import Optional, List, Dict, Any

# ---------- Basic Classes ----------
class Car:
    def __init__(self, car_id: int, model: str, price_per_day: float, plate: str):
        self.car_id = car_id          # key for BST
        self.model = model
        self.price_per_day = price_per_day
        self.plate = plate            # key for hash table
        self.available = True

    def __repr__(self):
        return f"Car({self.car_id}, {self.model}, {self.price_per_day}, {self.plate}, {'Available' if self.available else 'Rented'})"

class Customer:
    def __init__(self, customer_id: int, name: str, contact: str):
        self.customer_id = customer_id  # key for hash table
        self.name = name
        self.contact = contact

    def __repr__(self):
        return f"Customer({self.customer_id}, {self.name})"

class Rental:
    def __init__(self, rental_id: int, car: Car, customer: Customer, rent_date: datetime.date):
        self.rental_id = rental_id
        self.car = car
        self.customer = customer
        self.rent_date = rent_date
        self.return_date = None

    def __repr__(self):
        return f"Rental({self.rental_id}, Car {self.car.car_id}, Customer {self.customer.customer_id}, Rented: {self.rent_date})"
